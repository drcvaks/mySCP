{
  "expo": {
    "name": "mySCP",
    "slug": "myscp",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "myscp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0F5132"
      },
      "package": "com.chaimvaks.myscp"
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8beef5fe-5fa9-464c-b7e1-eb4a4ac5d445"
      }
    }
  }
}
